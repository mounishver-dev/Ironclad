# ══════════════════════════════════════════════════════════════════════
#  IRONCLAD — Root .gitignore
# ══════════════════════════════════════════════════════════════════════

# ── Secrets — NEVER commit ─────────────────────────────────────────────
.env
*.env
.env.local
.env.*.local
firebase_key.json
*_key.json
*serviceAccount*.json
*credentials*.json

# ── Python ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
venv/
.venv/
env/

# ── Node / React ────────────────────────────────────────────────────────
node_modules/
/build
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ── Temp files created by the backend ──────────────────────────────────
backend/uploads/
backend/temp_*.jpg
backend/temp_*.png
backend/temp_*.mp4
backend/checks/

# ── OS / IDE ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
