# ══════════════════════════════════════════════════════════════════════
#  Ironclad Backend — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the real .env file to GitHub.
# ══════════════════════════════════════════════════════════════════════

# Google Gemini API — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Firebase — Service account key file path (local only, never commit)
# Download firebase_key.json from Firebase Console → Project Settings → Service Accounts
# FIREBASE_KEY_PATH=firebase_key.json   ← already set in firebase_config.py
